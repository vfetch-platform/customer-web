    "crypto-js": "^4.2.0",
    "next": "14.2.35",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
